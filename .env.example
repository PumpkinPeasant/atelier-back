# App
APP_NAME=atelier-back
DEBUG=true

# PostgreSQL
POSTGRES_USER=atelier
POSTGRES_PASSWORD=atelier
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=atelier

# Auth / JWT (сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookie (secure=true при HTTPS в проде)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# S3 / MinIO (локальные значения совпадают с docker-compose)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=atelier
S3_REGION=us-east-1
# Публичный базовый URL файлов (CDN в проде). Пусто -> endpoint/bucket.
S3_PUBLIC_URL=
